{
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "e2e:install": "node scripts/e2e-install.mjs"
  },
  "devDependencies": {
    "@types/jsdom": "^28.0.3",
    "@vitest/coverage-v8": "^3.2.4",
    "jsdom": "^27.0.1",
    "vitest": "^3.2.4"
  }
}

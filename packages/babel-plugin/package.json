{
  "name": "@web-remarq/babel-plugin",
  "version": "0.0.1",
  "description": "Babel plugin for web-remarq source location injection",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@babel/core": "^7.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@types/babel__core": "^7.20.5",
    "@types/babel__traverse": "^7.28.0",
    "@types/node": "^22.15.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/DPostnik/web-remarq",
    "directory": "packages/babel-plugin"
  },
  "keywords": [
    "babel-plugin",
    "web-remarq",
    "source-location",
    "annotation"
  ]
}